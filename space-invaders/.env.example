# Space Invaders Session Server — Environment Variables
# Copy to .env and fill in values before running locally

# Server
PORT=8080
HOST=0.0.0.0

# GitHub Pages base URL (where the static HTML files are hosted)
DISPLAY_BASE=https://offline2online.github.io/rob_ph_demos/space-invaders/space-invaders-display.html
MOBILE_BASE=https://offline2online.github.io/rob_ph_demos/space-invaders/space-invaders-mobile.html
ENDED_BASE=https://offline2online.github.io/rob_ph_demos/space-invaders/space-invaders-ended.html

# Session TTL in milliseconds (default: 1 hour)
SESSION_TTL=3600000

# CORS — set to your GitHub Pages origin in production
ALLOWED_ORIGIN=https://offline2online.github.io
